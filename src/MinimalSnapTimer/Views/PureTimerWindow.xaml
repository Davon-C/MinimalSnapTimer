<Window x:Class="MinimalSnapTimer.Views.PureTimerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:services="clr-namespace:MinimalSnapTimer.Services"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="{Binding WindowTitle}"
        Width="292"
        Height="104"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="CanResize"
        Background="Transparent"
        ShowInTaskbar="{Binding ShowInTaskbar}"
        Topmost="{Binding IsAlwaysOnTop}"
        MouseEnter="Window_MouseEnter"
        MouseLeave="Window_MouseLeave"
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        MouseDoubleClick="Window_MouseDoubleClick"
        LocationChanged="Window_LocationChanged"
        SizeChanged="Window_SizeChanged"
        Loaded="Window_Loaded">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0" ResizeBorderThickness="8" GlassFrameThickness="0" />
    </shell:WindowChrome.WindowChrome>
    <Window.ContextMenu>
        <ContextMenu>
            <MenuItem Header="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[pure.startSit]}" Command="{Binding StartSitCommand}" />
            <MenuItem Header="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[pure.startStand]}" Command="{Binding StartStandCommand}" />
            <Separator />
            <MenuItem Header="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[pure.pauseResume]}" Command="{Binding PauseResumeCommand}" />
            <MenuItem Header="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[main.stop]}" Command="{Binding StopCommand}" />
            <MenuItem Header="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[main.reset]}" Command="{Binding ResetCommand}" />
            <Separator />
            <MenuItem Header="{Binding PureClickThroughMenuText}" Click="ToggleClickThroughMenuItem_Click" />
            <MenuItem Header="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[pure.returnStandard]}" Command="{Binding TogglePureModeCommand}" />
            <MenuItem Header="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[main.topmost]}" Command="{Binding ToggleAlwaysOnTopCommand}" />
            <MenuItem Header="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[main.settings]}" Command="{Binding OpenSettingsCommand}" />
        </ContextMenu>
    </Window.ContextMenu>
    <Grid>
        <Border x:Name="RootBorder"
                CornerRadius="10"
                Background="{Binding PureBackground}"
                Opacity="{Binding PureBackgroundOpacity}"
                BorderBrush="#40FFFFFF"
                BorderThickness="1">
            <Viewbox Stretch="Uniform">
                <TextBlock Margin="8,4"
                           Foreground="{Binding PureForeground}"
                           FontWeight="SemiBold"
                           Text="{Binding DisplayTime}" />
            </Viewbox>
        </Border>

        <Border x:Name="ToolbarBorder"
                HorizontalAlignment="Center"
                VerticalAlignment="Bottom"
                Margin="6"
                Padding="4"
                Background="{DynamicResource AppPureToolbarBackgroundBrush}"
                CornerRadius="8"
                Visibility="Collapsed">
            <StackPanel Orientation="Horizontal">
                <StackPanel Margin="2,0,8,0"
                            VerticalAlignment="Center">
                    <TextBlock Foreground="{DynamicResource ControlForegroundBrush}"
                               FontSize="10"
                               FontWeight="SemiBold"
                               Text="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[pure.modeBadge]}" />
                    <TextBlock Foreground="{DynamicResource MutedForegroundBrush}"
                               FontSize="10"
                               Text="{Binding StatusText}" />
                </StackPanel>
                <Button Margin="2" Padding="8,2" Command="{Binding PauseResumeCommand}" Content="{Binding PauseResumeText}" />
                <Button Margin="2" Padding="8,2" Command="{Binding ResetCommand}" Content="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[main.reset]}" />
                <Button Margin="2" Padding="8,2" Command="{Binding TogglePureModeCommand}" Content="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[main.standardMode]}" />
                <Button Margin="2" Padding="8,2" Command="{Binding OpenSettingsCommand}" Content="{Binding Source={x:Static services:LocalizationService.Instance}, Path=[main.settings]}" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
